Checks: >
    bugprone-*,
    clang-analyzer-*,
    cppcoreguidelines-*,
    performance-*,
    portability-*,
    readability-*,
    -cppcoreguidelines-avoid-magic-numbers,
    -readability-named-parameter,
    -readability-identifier-length

WarningsAsErrors: '*'
HeaderFilterRegex: '.*'
FormatStyle: none
